# =========================================================================
# AI IMAGE PROCESSING PIPELINE SERVICE - CONFIGURATION (EXAMPLE)
# =========================================================================

PORT=3002

# 1. OpenRouter (Detect Object)
# Để trống nếu muốn chạy Mock Bounding Box tự động
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=

# 2. Local Python AI Worker (Tách nền & Inpaint xóa đối tượng 100% cục bộ miễn phí)
# Đường dẫn API Python worker, cổng mặc định 8000
# Khởi động worker bằng lệnh: cd python_worker && uvicorn main:app --port 8000
PYTHON_BG_REMOVAL_URL=http://localhost:8000/remove-bg

# 3. AWS S3 Storage (Bộ lưu trữ lai - Tùy chọn)
# Để trống nếu muốn chạy Local Fallback lưu file trên đĩa cứng EC2/PC
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here
